import urllib.parse
from urllib3.exceptions import InsecureRequestWarning

# COLORS
RE = '\033[0m'
G = '\033[32m'
R = '\033[31m'
Y = '\033[33m'
B = '\033[34m'
C = '\033[36m'
P = '\033[35m'
WB = '\033[1;37m'
GB = '\033[1;32m'
RB = '\033[1;31m'
YB = '\033[1;33m'
BB = '\033[1;34m'
CB = '\033[1;36m'
PB = '\033[1;35m'

def printrun(s, end='\n', flush=False):
    if end == '':
        for c in s:
            sys.stdout.write(c)
            sys.stdout.flush()
            time.sleep(3.0 / 95)
        if flush:
            sys.stdout.flush()
    else:
        for c in s + end:
            sys.stdout.write(c)
            sys.stdout.flush()
            time.sleep(3.0 / 100)

warnings.simplefilter('ignore', InsecureRequestWarning)

def decode_title(title):
    if not title:
        return "No Title"
    try:
        return html.unescape(title.strip())
    except:
        return title.strip()

loading = False
loading_lock = threading.Lock()
animation_thread = None

def animate_loading():
    global loading
    spinner = itertools.cycle(['⣾', '⣽', '⣻', '⢿', '⡿', '⣟', '⣯', '⣷'])
    while loading:
        with loading_lock:
            sys.stdout.write(f'\r[{WB}⟳{RE}] Scanning in progress... {next(spinner)}   ')
            sys.stdout.flush()
            time.sleep(0.15)
    sys.stdout.write('\r' + ' ' * 50 + '\r')
    sys.stdout.flush()

def start_loading():
    global loading, animation_thread
    with loading_lock:
        if loading:
            return
        loading = True
    animation_thread = threading.Thread(target=animate_loading, daemon=True)
    animation_thread.start()

def stop_loading():
    global loading
    with loading_lock:
        loading = False
    time.sleep(0.2)
    sys.stdout.write('\r' + ' ' * 60 + '\r')
    sys.stdout.flush()

